# ============================================================
# debuga.ai — Exemplo de .env
# ============================================================
# Para produção: cp templates/.env.production.template .env
# Para homologação: cp templates/.env.homolog.template .env
# Validar: bash scripts/validate-env.sh
# ============================================================

NODE_ENV=production
COMPOSE_PROJECT_NAME=debuga
DOMAIN=debuga.ai
APP_URL=https://debuga.ai
PORT=3000

POSTGRES_USER=debuga
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=debuga_prod
DATABASE_URL=postgresql://debuga:CHANGE_ME@postgres:5432/debuga_prod

JWT_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME

ENABLE_LOCAL_LOGIN=true
ADMIN_EMAIL=admin@debuga.ai

LLM_PROVIDER=local
LLM_FALLBACK_PROVIDER=openai
OPENAI_API_KEY=CHANGE_ME
ENABLE_LOCAL_INFERENCE=true
LOCAL_LLM_BASE_URL=http://ollama:11434
LOCAL_LLM_MODEL=qwen2.5:7b-instruct

S3_BUCKET=debuga-prod
S3_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=debuga
MINIO_ROOT_PASSWORD=CHANGE_ME

# Consulte templates/.env.production.template para lista completa
