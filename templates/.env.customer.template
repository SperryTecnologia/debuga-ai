# ============================================================
# debuga.ai — Template CLIENTE WHITE LABEL
# ============================================================
# Este template é a base para provisionar novos clientes.
# Copie, substitua os placeholders e configure para o cliente.
#
# Uso:
#   cp templates/.env.customer.template .env
#   chmod 600 .env
#   # Substituir todos os valores marcados com CHANGE_ME
#   # Substituir "cliente_slug" pelo identificador do cliente
#   # Substituir "ia.cliente.com.br" pelo domínio do cliente
#   nano .env
#   bash scripts/validate-all.sh --env .env
#
# Gerar secrets: openssl rand -base64 48
# ============================================================

# ── 1. Ambiente ──
NODE_ENV=production
COMPOSE_PROJECT_NAME=cliente_slug
DOMAIN=ia.cliente.com.br
APP_URL=https://ia.cliente.com.br
AUTH_BASE_URL=https://ia.cliente.com.br
PORT=3000

# ── 2. App/Frontend ──
# Personalizar com marca do cliente
VITE_APP_TITLE=Nome da Solução
VITE_APP_ID=cliente-slug
VITE_APP_LOGO=

# ── 3. Banco de Dados ──
# Cada cliente deve ter banco isolado
POSTGRES_USER=cliente_slug
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_64CHARS
POSTGRES_DB=cliente_slug_prod
DATABASE_URL=postgresql://cliente_slug:CHANGE_ME_STRONG_PASSWORD_64CHARS@postgres:5432/cliente_slug_prod

# ── 4. Sessões/JWT ──
JWT_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_64
SESSION_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=7d

# ── 5. Login Local ──
ENABLE_LOCAL_LOGIN=true
ADMIN_EMAIL=CHANGE_ME_ADMIN_EMAIL_CLIENTE

# ── 6. Google OAuth ──
# Redirect URI: https://ia.cliente.com.br/api/auth/google/callback
# O cliente pode fornecer suas próprias credenciais OAuth
ENABLE_GOOGLE_OAUTH=true
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
VITE_OAUTH_PORTAL_URL=/api/auth/google

# ── 7. Auth Hardening ──
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=true
REQUIRE_EMAIL_FOR_CHAT=true
REQUIRE_TERMS_ACCEPTANCE=true
BLOCK_DISPOSABLE_EMAILS=true

# ── 8. SMTP/Brevo ──
SMTP_PROVIDER=brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@ia.cliente.com.br
SMTP_FROM_NAME=Nome da Solução
SMTP_REPLY_TO=suporte@cliente.com.br

# ── 9. Turnstile ──
ENABLE_TURNSTILE=true
TURNSTILE_SITE_KEY=CHANGE_ME
TURNSTILE_SECRET_KEY=CHANGE_ME
TURNSTILE_ON_LOGIN=true

# ── 10. Telefone/WhatsApp ──
PHONE_VERIFICATION_ENABLED=false
PHONE_VERIFICATION_REQUIRED=false
REQUIRE_PHONE_FOR_CHAT=false
PHONE_PROVIDER=none
PHONE_OTP_TTL_MINUTES=10
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── 11. LLM Providers ──
LLM_PROVIDER=local
LLM_FALLBACK_PROVIDER=openai

LLM_CLOUD_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_CLOUD_API_KEY=CHANGE_ME
LLM_CLOUD_MODEL=gemini-2.5-flash

GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── 12. GPU Local (Ollama) ──
# Se o cliente tem GPU dedicada
ENABLE_LOCAL_INFERENCE=true
LOCAL_LLM_BASE_URL=http://ollama:11434
LOCAL_LLM_HOST_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen2.5:7b-instruct
LOCAL_LLM_PRIORITY=first
LOCAL_LLM_TIMEOUT_SECONDS=30
LOCAL_LLM_FALLBACK_ENABLED=true
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KEEP_ALIVE=-1

# ── 13. Storage ──
# Cada cliente deve ter bucket isolado
MINIO_ROOT_USER=cliente_slug
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD_64CHARS
S3_ACCESS_KEY=cliente_slug
S3_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD_64CHARS
S3_BUCKET=cliente-slug-assets
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
MINIO_BUCKET=cliente-slug-assets

# ── 14. Stripe ──
# Configurar com conta Stripe do operador ou do cliente
STRIPE_SECRET_KEY=CHANGE_ME_SK_LIVE
STRIPE_WEBHOOK_SECRET=CHANGE_ME
VITE_STRIPE_PUBLISHABLE_KEY=CHANGE_ME_PK_LIVE
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

# ── 15. Analytics ──
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── 16. White Label ──
WHITE_LABEL_ENABLED=true
APP_NAME=Nome da Solução
WHITE_LABEL_COMPANY_NAME=Nome da Empresa
VITE_SUPPORT_EMAIL=suporte@cliente.com.br
VITE_SUPPORT_WHATSAPP=+55XXXXXXXXXXX
PRIVACY_POLICY_URL=https://ia.cliente.com.br/privacidade
TERMS_OF_USE_URL=https://ia.cliente.com.br/termos
LEGAL_COMPANY_NAME=Nome da Empresa LTDA

# ── 17. Logs ──
LOG_LEVEL=warn
AUDIT_LOG_ENABLED=true

# ── 18. Segurança ──
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=5
CHAT_RATE_LIMIT_WINDOW_MINUTES=1
CHAT_RATE_LIMIT_MAX=15

# ── 19. Owner ──
OWNER_OPEN_ID=
OWNER_NAME=

# ── 20. Capability Orchestrator ──
ENABLE_CAPABILITY_ROUTING=true
ENABLE_KNOWLEDGE_REUSE=true
ENABLE_LEARNING=true

# ── 21. Image Generation ──
IMAGE_GENERATION_ENABLED=true
IMAGE_GENERATION_PROVIDER=openai
IMAGE_OPENAI_MODEL=dall-e-3
IMAGE_GEMINI_MODEL=imagen-3
REPLICATE_API_TOKEN=
IMAGE_REPLICATE_MODEL=black-forest-labs/flux-schnell

# ── 22. Video Generation ──
VIDEO_GENERATION_ENABLED=false
VIDEO_GENERATION_PROVIDER=replicate
VIDEO_REPLICATE_MODEL=minimax/video-01-live
RUNWAY_API_KEY=
RUNWAY_MODEL=gen3a_turbo
VEO_API_KEY=
VEO_MODEL=veo-2.0-generate-001

# ── 23. Diagram Generation ──
DIAGRAM_GENERATION_ENABLED=true

# ── 24. Cost Safety ──
# Definir limites conforme contrato do cliente
COST_DAILY_LIMIT_USD=10.00
COST_MONTHLY_LIMIT_USD=300.00
COST_ALERT_THRESHOLD_PERCENT=80
