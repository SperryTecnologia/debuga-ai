# ============================================================
# debuga.ai — Template CLOUD-ONLY (Sem Ollama)
# ============================================================
# Para ambientes 100% cloud, sem GPU e sem Ollama.
# Deploy mais leve — não sobe container Ollama.
# Toda inferência via OpenAI/Anthropic/Gemini/OpenRouter.
#
# Uso: cp templates/.env.cloud-only.template .env
# Validar: bash scripts/validate-all.sh --env .env
# Gerar secrets: openssl rand -base64 48
#
# Requisitos:
#   - 2+ cores CPU
#   - 4+ GB RAM
#   - 30+ GB SSD
#   - Chaves de API de pelo menos 1 provider cloud
#   - Sem GPU, sem NVIDIA, sem Ollama
#
# Docker Compose: usar docker-compose.yml SEM o serviço ollama
# Ou definir COMPOSE_PROFILES=app (sem gpu profile)
# ============================================================

# ── 1. Ambiente ──
NODE_ENV=production
COMPOSE_PROJECT_NAME=CHANGE_ME_PROJECT_NAME
DOMAIN=CHANGE_ME_DOMAIN
APP_URL=https://CHANGE_ME_DOMAIN
AUTH_BASE_URL=https://CHANGE_ME_DOMAIN
PORT=3000

# ── 2. App/Frontend ──
VITE_APP_TITLE=CHANGE_ME_APP_NAME
VITE_APP_ID=CHANGE_ME_APP_ID
VITE_APP_LOGO=

# ── 3. Banco de Dados ──
POSTGRES_USER=CHANGE_ME_DB_USER
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_64CHARS
POSTGRES_DB=CHANGE_ME_DB_NAME
DATABASE_URL=postgresql://CHANGE_ME_DB_USER:CHANGE_ME_STRONG_PASSWORD_64CHARS@postgres:5432/CHANGE_ME_DB_NAME

# ── 4. Sessões/JWT ──
JWT_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_64
SESSION_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=7d

# ── 5. Login Local ──
ENABLE_LOCAL_LOGIN=true
ADMIN_EMAIL=CHANGE_ME_ADMIN_EMAIL

# ── 6. Google OAuth ──
ENABLE_GOOGLE_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_OAUTH_PORTAL_URL=/api/auth/google

# ── 7. Auth Hardening ──
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=true
REQUIRE_EMAIL_FOR_CHAT=true
REQUIRE_TERMS_ACCEPTANCE=true
BLOCK_DISPOSABLE_EMAILS=true

# ── 8. SMTP ──
SMTP_PROVIDER=brevo
SMTP_HOST=CHANGE_ME_SMTP_HOST
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=CHANGE_ME_NOREPLY_EMAIL
SMTP_FROM_NAME=CHANGE_ME_APP_NAME
SMTP_REPLY_TO=CHANGE_ME_SUPPORT_EMAIL

# ── 9. Turnstile ──
ENABLE_TURNSTILE=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_ON_LOGIN=false

# ── 10. Telefone/WhatsApp ──
PHONE_VERIFICATION_ENABLED=false
PHONE_VERIFICATION_REQUIRED=false
REQUIRE_PHONE_FOR_CHAT=false
PHONE_PROVIDER=none
PHONE_OTP_TTL_MINUTES=10
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── 11. LLM Providers — CLOUD PRINCIPAL ──
LLM_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic

LLM_CLOUD_API_URL=https://api.openai.com/v1
LLM_CLOUD_API_KEY=CHANGE_ME_OPENAI_KEY
LLM_CLOUD_MODEL=gpt-4o-mini

GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=CHANGE_ME_GEMINI_KEY
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=CHANGE_ME_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_KEY
ANTHROPIC_MODEL=claude-sonnet-4-20250514

OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── 12. GPU Local — COMPLETAMENTE DESABILITADA ──
ENABLE_LOCAL_INFERENCE=false
LOCAL_LLM_BASE_URL=
LOCAL_LLM_HOST_URL=
LOCAL_LLM_MODEL=
LOCAL_LLM_PRIORITY=disabled
LOCAL_LLM_TIMEOUT_SECONDS=0
LOCAL_LLM_FALLBACK_ENABLED=false
OLLAMA_NUM_PARALLEL=0
OLLAMA_MAX_LOADED_MODELS=0
OLLAMA_FLASH_ATTENTION=0
OLLAMA_KEEP_ALIVE=0

# ── 13. Storage ──
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD_64CHARS
S3_ACCESS_KEY=CHANGE_ME_MINIO_USER
S3_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD_64CHARS
S3_BUCKET=CHANGE_ME_BUCKET_NAME
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
MINIO_BUCKET=CHANGE_ME_BUCKET_NAME

# ── 14. Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

# ── 15. Analytics ──
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── 16. White Label ──
WHITE_LABEL_ENABLED=true
VITE_SUPPORT_EMAIL=CHANGE_ME_SUPPORT_EMAIL
VITE_SUPPORT_WHATSAPP=CHANGE_ME_WHATSAPP
PRIVACY_POLICY_URL=https://CHANGE_ME_DOMAIN/privacidade
TERMS_OF_USE_URL=https://CHANGE_ME_DOMAIN/termos
LEGAL_COMPANY_NAME=CHANGE_ME_COMPANY_NAME

# ── 17. Logs ──
LOG_LEVEL=warn
AUDIT_LOG_ENABLED=true

# ── 18. Segurança ──
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=5
CHAT_RATE_LIMIT_WINDOW_MINUTES=1
CHAT_RATE_LIMIT_MAX=15

# ── 19. Owner ──
OWNER_OPEN_ID=
OWNER_NAME=

# ── 20. Capability Orchestrator ──
ENABLE_CAPABILITY_ROUTING=true
ENABLE_KNOWLEDGE_REUSE=true
ENABLE_LEARNING=true

# ── 21. Image Generation ──
# Cloud-only: usar OpenAI DALL-E ou Replicate
IMAGE_GENERATION_ENABLED=true
IMAGE_GENERATION_PROVIDER=openai
IMAGE_OPENAI_MODEL=dall-e-3
IMAGE_GEMINI_MODEL=imagen-3
REPLICATE_API_TOKEN=
IMAGE_REPLICATE_MODEL=black-forest-labs/flux-schnell
IMAGE_PROVIDER_ORDER=openai_image,replicate,gemini_image

# ── 22. Video Generation ──
VIDEO_GENERATION_ENABLED=false
VIDEO_GENERATION_PROVIDER=replicate
VIDEO_REPLICATE_MODEL=minimax/video-01-live
RUNWAY_API_KEY=
RUNWAY_MODEL=gen3a_turbo
VEO_API_KEY=
VEO_MODEL=veo-2.0-generate-001

# ── 23. Diagram Generation ──
DIAGRAM_GENERATION_ENABLED=true

# ── 24. Cost Safety ──
# Cloud-only terá custos maiores — monitorar de perto
COST_DAILY_LIMIT_USD=30.00
COST_MONTHLY_LIMIT_USD=800.00
COST_ALERT_THRESHOLD_PERCENT=70
